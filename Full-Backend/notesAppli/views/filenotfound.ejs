<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 — File Not Found</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter,system-ui,sans-serif;
}

body{
    height:100vh;
    display:grid;
    place-items:center;
    background:#fff;
    color:#111;
}

.container{
    text-align:center;
    padding:2rem;
}

.code{
    font-size:7rem;
    font-weight:700;
    line-height:1;
    letter-spacing:-4px;
}

h1{
    margin-top:1rem;
    font-size:1.5rem;
    font-weight:600;
}

p{
    margin-top:.75rem;
    color:#666;
    max-width:400px;
}

a{
    display:inline-block;
    margin-top:2rem;
    padding:.8rem 1.2rem;
    text-decoration:none;
    color:#111;
    border:1px solid #ddd;
    border-radius:10px;
    transition:.2s ease;
}

a:hover{
    background:#111;
    color:#fff;
    border-color:#111;
}
</style>
</head>
<body>

<div class="container">
    <div class="code">404</div>
    <h1>File not found</h1>
    <p>
        The file you're looking for doesn't exist or has been moved.
    </p>

    <a href="/">Return Home</a>
</div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="w-full min-h-screen bg-zinc-900 p-10 text-white">

    <a class="text-blue-500 hover:underline" href="/">
        Back to Home
    </a>

    <h1 class="text-3xl mt-10 tracking-tighter mb-6">
        All Users
    </h1>

    <div class="users flex gap-4 flex-wrap">

        <% if(users.length > 0) { %>

            <% users.forEach(function(user) { %>

                <div class="user w-72 p-4 bg-zinc-800 rounded-lg">

                    <% if(user.image) { %>
                        <img
                            src="<%= user.image %>"
                            alt="User Image"
                            class="w-full h-52 rounded-lg object-cover"
                        >
                    <% } else { %>
                        <div class="w-full h-52 rounded-lg bg-zinc-700"></div>
                    <% } %>

                    <h3 class="text-xl mt-3 tracking-tighter">
                        <%= user.name %>
                    </h3>

                    <h5 class="text-zinc-400">
                        <%= user.email %>
                    </h5>

                    <div class="flex gap-4 mt-5">
                        <a
                            href="/edit/<%= user._id %>" 
                            class="text-yellow-400 hover:underline"
                        >
                            Edit User
                        </a>

                        <a
                            href="/delete/<%= user._id %>"
                            class="text-red-500 hover:underline"
                        >
                            Delete
                        </a>
                    </div>

                </div>

            <% }) %>

        <% } else { %>

            <h2 class="text-zinc-400 text-xl">
                No Users Found
            </h2>

        <% } %>

    </div>

</body>
</html>
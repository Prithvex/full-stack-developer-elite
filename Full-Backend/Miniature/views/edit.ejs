<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 text-white">
    <div class="w-full h-screen p-10">
        <h3 class="text-2xl mb-4">Edit Post</h3>
        <form action="/edit/<%= post._id %>" method="POST">
            <textarea 
                name="content"
                class="block p-3 outline-none w-full md:w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md focus:border-blue-500"
                rows="6"
            ><%= post.content %></textarea>
            <button 
                type="submit"
                class="px-5 py-2 rounded-md bg-yellow-500 hover:bg-yellow-600 mt-3"
            >
                Update Post
            </button>
        </form>
    </div>
</body>
</html>
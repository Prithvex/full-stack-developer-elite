<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 text-white">
    <div class="w-full h-screen p-10">
        <!-- Logout Button -->
        <div class="w-full flex justify-end p-4">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>

        <!-- Greeting -->
        <div class="flex items-start gap-3">
            <div class="w-10 h-10  rounded-md">
                <!-- profile image show karo -->
                 <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="">
            </div>
                <h3 class="text-3xl"><span class="font-light">Hello</span> <%= user.name %></h3>
            </div>
        <h5 class="mb-5">You can create a new post.</h5>

        <!-- Post Creation Form -->
        <form method="post" action="/post">
            <textarea 
                name="content"
                placeholder="What's on your mind?"
                class="block p-3 outline-none w-full md:w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md focus:border-blue-500"
                rows="4"
            ></textarea>
            <input 
                class="px-3 py-2 text-sm bg-blue-500 block rounded-md mt-2 cursor-pointer hover:bg-blue-600" 
                type="submit" 
                value="Create Post"
            />
        </form>

        <!-- Posts Section -->
        <div class="posts mt-20">
            <h3 class="text-zinc-400 text-xl mb-4">Your Posts.</h3>
            <div class="postcontainer mt-5 space-y-4">
                <% if (user.posts && user.posts.length > 0) { %>
                    <% user.posts.slice().reverse().forEach(function(post) { %>
                        <div class="post w-full md:w-1/3 p-4 mb-4 rounded-md border border-zinc-700 bg-zinc-800">
                            <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
                            <p class="text-sm tracking-tight"><%= post.content %></p>
                            <small class="mt-2 inline-block"><%= post.likes.length %> Likes</small>
                            <div class="btns flex gap-4 mt-1">
                                <!-- Like/Unlike toggle form -->
                                <form action="/like/<%= post._id %>" method="POST" class="inline">
                                    <% 
                                      const alreadyLiked = post.likes.some(id => id.toString() === currentUserId);
                                    %>
                                    <button type="submit" class="text-blue-500 bg-transparent border-none cursor-pointer p-0">
                                        <%= alreadyLiked ? 'Unlike' : 'Like' %>
                                    </button>
                                </form>
                                <!-- Edit link -->
                                <a class="text-zinc-600 hover:text-zinc-400" href="/edit/<%= post._id %>">Edit</a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-zinc-500">You haven't created any posts yet.</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>